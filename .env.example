ENVIRONMENT=development
LOG_LEVEL=INFO

POSTGRES_DB=yggdrasil
POSTGRES_USER=yggdrasil
POSTGRES_PASSWORD=local_development_only
DATABASE_URL=postgresql://yggdrasil:local_development_only@postgres:5432/yggdrasil

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434
RAG_EMBEDDING_DIMENSIONS=256
RAG_CACHE_TTL_SECONDS=300
RAG_INDEX_MAX_ATTEMPTS=5
RAG_QDRANT_TIMEOUT_SECONDS=5
WORKER_HEARTBEAT_TTL_SECONDS=45
AI_PROVIDER_ORDER=gemini,groq,openai,anthropic,openrouter,ollama,cached
AI_CLOUD_TIMEOUT_SECONDS=10
AI_LOCAL_TIMEOUT_SECONDS=30
AI_PROVIDER_ATTEMPTS=2
AI_REQUESTS_PER_MINUTE=20
AI_REQUESTS_PER_HOUR=200
AI_MAX_OUTPUT_TOKENS=1000

# Provider credentials and model IDs are deployment configuration.
GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OLLAMA_MODEL=

BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=8080

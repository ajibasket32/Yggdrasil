ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
POSTGRES_DB=yggdrasil
POSTGRES_USER=yggdrasil
POSTGRES_PASSWORD=yggdrasil_local_only
DATABASE_URL=postgresql://yggdrasil:yggdrasil_local_only@postgres:5432/yggdrasil

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
RAG_EMBEDDING_DIMENSIONS=256

# AI Providers
AI_PROVIDER_ORDER=cached
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama3-8b-8192
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2:1b

# Docker Image Overrides
# Use these if you run into Docker Hub rate limits
# POSTGRES_IMAGE=public.ecr.aws/docker/library/postgres:16.9-alpine
# REDIS_IMAGE=public.ecr.aws/docker/library/redis:7.4.2-alpine
# NGINX_IMAGE=public.ecr.aws/nginx/nginx:1.28.0-alpine
# QDRANT_IMAGE=qdrant/qdrant:v1.9.0
# OLLAMA_IMAGE=ollama/ollama:0.6.8


ENVIRONMENT=test
LOG_LEVEL=WARNING

POSTGRES_DB=yggdrasil_test
POSTGRES_USER=yggdrasil_test
POSTGRES_PASSWORD=yggdrasil_test_local_only
DATABASE_URL=postgresql://yggdrasil_test:yggdrasil_test_local_only@127.0.0.1:15432/yggdrasil_test

REDIS_URL=redis://127.0.0.1:16379/1
QDRANT_URL=http://127.0.0.1:16333
OLLAMA_URL=http://127.0.0.1:11434
RAG_EMBEDDING_DIMENSIONS=256
RAG_CACHE_TTL_SECONDS=60
RAG_INDEX_MAX_ATTEMPTS=3
RAG_QDRANT_TIMEOUT_SECONDS=5
WORKER_HEARTBEAT_TTL_SECONDS=45
AI_PROVIDER_ORDER=cached
AI_CLOUD_TIMEOUT_SECONDS=1
AI_LOCAL_TIMEOUT_SECONDS=1
AI_PROVIDER_ATTEMPTS=1
AI_REQUESTS_PER_MINUTE=100
AI_REQUESTS_PER_HOUR=1000
AI_MAX_OUTPUT_TOKENS=1000

GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OLLAMA_MODEL=

TEST_POSTGRES_PORT=15432
TEST_REDIS_PORT=16379
TEST_QDRANT_HTTP_PORT=16333
TEST_QDRANT_GRPC_PORT=16334

# Docker Image Overrides
POSTGRES_IMAGE=public.ecr.aws/docker/library/postgres:16.9-alpine
REDIS_IMAGE=public.ecr.aws/docker/library/redis:7.4.2-alpine
NGINX_IMAGE=public.ecr.aws/nginx/nginx:1.28.0-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.9.0
OLLAMA_IMAGE=ollama/ollama:0.6.8
